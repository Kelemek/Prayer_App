# Supabase Configuration (frontend — Vite)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# Example:
# VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_... (Dashboard → Settings → API Keys → publishable)

# Server-side only (e.g. process-email-queue, restore/backup workflows — never bundle into the Angular app)
# Supabase Dashboard → Settings → API Keys → Secret (sb_secret_...). Prefer this over the legacy service_role JWT.
# SUPABASE_SECRET_KEY=sb_secret_...

# Email (not Vite — configure in Supabase Edge Function secrets and GitHub Actions for queue processing)
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_SENDER_ADDRESS=noreply@your-verified-domain.com
# MAIL_FROM_NAME=Prayer Ministry
